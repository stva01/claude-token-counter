{
  "manifest_version": 3,
  "name": "Token Counter",
  "version": "1.0.0",
  "description": "Real-time token usage tracker for AI assistants — session quota, weekly quota, context window, and cache timer.",
  "permissions": [
    "storage",
    "cookies",
    "alarms"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Token Counter"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
